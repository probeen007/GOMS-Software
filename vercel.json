{
  "version": 2,
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/index.js" },
    { "src": "^/$", "dest": "/site/index.html" },
    { "src": "^/about\\.html$", "dest": "/site/about.html" },
    { "src": "^/services\\.html$", "dest": "/site/services.html" },
    { "src": "^/gallery\\.html$", "dest": "/site/gallery.html" },
    { "src": "^/contact\\.html$", "dest": "/site/contact.html" },
    { "src": "^/book\\.html$", "dest": "/site/book.html" },
    { "handle": "filesystem" },
    { "src": "^/(?!api/|site/|user-manual\\.html).*$", "dest": "/index.html" }
  ]
}
