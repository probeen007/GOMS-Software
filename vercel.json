{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/", "destination": "/site/index.html" },
    { "source": "/about.html", "destination": "/site/about.html" },
    { "source": "/services.html", "destination": "/site/services.html" },
    { "source": "/gallery.html", "destination": "/site/gallery.html" },
    { "source": "/contact.html", "destination": "/site/contact.html" },
    { "source": "/book.html", "destination": "/site/book.html" },
    { "source": "/((?!api/|site/|user-manual\\.html).*)", "destination": "/index.html" }
  ]
}
